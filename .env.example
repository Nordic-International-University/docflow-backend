DATABASE_URL="postgresql://postgres:mypassword@localhost:5432/repository?schema=public"

# JWT Configuration (REQUIRED - Generate strong random strings)
# Generate secure random secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-super-secret-access-key-minimum-32-chars-change-this-immediately
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars-change-this-immediately

# JWT Expiration Times (optional, defaults shown)
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET_NAME=university-repository

# Seed Scripts Configuration
# API_URL - Base URL for seed scripts (default: http://localhost:5058)
API_URL=http://localhost:5058
# AUTH_TOKEN - JWT token for authentication (required for most seed scripts)
# Get this by logging in: curl -X POST http://localhost:5058/api/v1/auth/login -H "Content-Type: application/json" -d '{"username":"admin","password":"your-password"}'
AUTH_TOKEN=your-jwt-token-here