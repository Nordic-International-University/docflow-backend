{
  "name": "nordic-repository",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "prebuild": "npm run lint:fix && npm run format",
    "build": "rm -rf dist && tsc && tsc-alias --project tsconfig.build.json",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "alias": "tsc-alias --project tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:seed": "npx ts-node --transpile-only prisma/seed.ts",
    "db:migrate": "npx prisma migrate dev --config prisma/prisma.config.ts",
    "db:push": "npx prisma db push --config prisma/prisma.config.ts",
    "db:generate": "npx prisma generate --config prisma/prisma.config.ts",
    "db:studio": "npx prisma studio --config prisma/prisma.config.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest --testPathPattern='\\.spec\\.ts$'",
    "test:e2e": "jest --testPathPattern='e2e-spec\\.ts$' --runInBand",
    "test:api": "jest --testPathPattern='api\\.spec\\.ts$' --runInBand"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@casl/prisma": "^1.6.2",
    "@docverse-pdf/server": "^1.1.2",
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.12",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/microservices": "^11.1.9",
    "@nestjs/platform-express": "^11.0.20",
    "@nestjs/platform-socket.io": "^11.1.11",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.2",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "argon2": "^0.41.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "cookie-session": "^2.1.1",
    "date-fns": "^4.1.0",
    "docxtemplater": "^3.67.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "ioredis": "^5.8.2",
    "minio": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.3",
    "pizzip": "^3.2.0",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "telegraf": "^4.16.3",
    "tsc-alias": "^1.8.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.0.12",
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.13",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma": "^7.0.1",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2"
  }
}
