// ============ KPI SYSTEM (Task-Based Scoring) ============

enum KpiRewardStatus {
  PENDING       // Waiting for approval
  APPROVED      // Approved for payment
  PAID          // Already paid
  REJECTED      // Rejected
}

// Task Score Configuration - Defines points per priority level
// This maps to your Excel: Priority №1-10 with their scores and penalties
model TaskScoreConfig {
  id                  String                      @map("id")                  @db.Uuid            @default(dbgenerated("GEN_RANDOM_UUID()"))

  // Priority level (1 = highest, 10 = lowest)
  priorityLevel       Int                         @map("priority_level")      @db.Integer         @unique
  priorityCode        String                      @map("priority_code")       @db.VarChar(10)     // "№1", "№2", etc.

  // Score configuration
  baseScore           Int                         @map("base_score")          @db.Integer         // 5, 10, 15, 20, 25, 30, 35, 40, 45, 50

  // Deadline configuration
  recommendedDays     Int                         @map("recommended_days")    @db.Integer         // 1, 3, 4, 5, 6, 7, 8, 9, 10, 12

  // Penalty configuration
  penaltyPerDay       Int                         @map("penalty_per_day")     @db.Integer         // -5 or -10
  maxPenaltyDays      Int?                        @map("max_penalty_days")    @db.Integer         // Optional: max days penalty applies

  // Description
  description         String                      @map("description")         @db.Text
  criteria            String?                     @map("criteria")            @db.Text            // Measurable criteria

  isActive            Boolean                     @map("is_active")           @db.Boolean         @default(true)

  createdAt           DateTime                    @map("created_at")          @db.Timestamp       @default(now())
  updatedAt           DateTime                    @map("updated_at")          @db.Timestamp       @updatedAt
  deletedAt           DateTime?                   @map("deleted_at")          @db.Timestamp

  @@id([ id ])
  @@index([priorityLevel])
  @@index([isActive])
  @@map("task_score_config")
}

// Reward Tier Configuration - Defines reward tiers based on monthly score
// This maps to your Excel: 0-45, 50-65, 70-80, 85-95, 100
model KpiRewardTier {
  id                  String                      @map("id")                  @db.Uuid            @default(dbgenerated("GEN_RANDOM_UUID()"))

  // Score range
  minScore            Int                         @map("min_score")           @db.Integer
  maxScore            Int                         @map("max_score")           @db.Integer

  // Reward configuration
  rewardAmount        Decimal?                    @map("reward_amount")       @db.Decimal(15, 2)  // Amount in local currency
  rewardBhm           Decimal?                    @map("reward_bhm")          @db.Decimal(5, 2)   // BHM multiplier (5, 10, 15)

  // Penalty flag (for scores below threshold)
  isPenalty           Boolean                     @map("is_penalty")          @db.Boolean         @default(false)
  penaltyType         String?                     @map("penalty_type")        @db.VarChar(50)     // "WARNING", "FINANCIAL", etc.

  // Display
  name                String                      @map("name")                @db.VarChar(100)    // "Excellent", "Good", "Acceptable", etc.
  description         String?                     @map("description")         @db.VarChar(500)
  color               String?                     @map("color")               @db.VarChar(7)      // For UI display

  isActive            Boolean                     @map("is_active")           @db.Boolean         @default(true)

  rewards             KpiReward[]

  createdAt           DateTime                    @map("created_at")          @db.Timestamp       @default(now())
  updatedAt           DateTime                    @map("updated_at")          @db.Timestamp       @updatedAt
  deletedAt           DateTime?                   @map("deleted_at")          @db.Timestamp

  @@id([ id ])
  @@index([minScore, maxScore])
  @@map("kpi_reward_tier")
}

// Task KPI Score - Individual task score record (earned when task is completed)
model TaskKpiScore {
  id                  String                      @map("id")                  @db.Uuid            @default(dbgenerated("GEN_RANDOM_UUID()"))

  taskId              String                      @map("task_id")             @db.Uuid
  userId              String                      @map("user_id")             @db.Uuid            // The assignee who completed it

  // Score details
  baseScore           Int                         @map("base_score")          @db.Integer         // Base score from priority
  earnedScore         Int                         @map("earned_score")        @db.Integer         // Actual earned score (after penalties)
  penaltyApplied      Int                         @map("penalty_applied")     @db.Integer         @default(0)  // Total penalty deducted

  // Timing details
  dueDate             DateTime                    @map("due_date")            @db.Date
  completedDate       DateTime                    @map("completed_date")      @db.Date
  daysLate            Int                         @map("days_late")           @db.Integer         @default(0)

  // Period this score belongs to
  periodYear          Int                         @map("period_year")         @db.Integer
  periodMonth         Int                         @map("period_month")        @db.Integer

  // Breakdown for transparency
  // {"baseScore": 20, "daysLate": 2, "penaltyPerDay": -5, "totalPenalty": -10, "earned": 10}
  breakdown           Json?                       @map("breakdown")           @db.JsonB

  createdAt           DateTime                    @map("created_at")          @db.Timestamp       @default(now())
  updatedAt           DateTime                    @map("updated_at")          @db.Timestamp       @updatedAt

  @@id([ id ])
  @@unique([taskId, userId])
  @@index([userId])
  @@index([periodYear, periodMonth])
  @@index([completedDate])
  @@map("task_kpi_score")
}

// User Monthly KPI Summary - Aggregated monthly score per user
model UserMonthlyKpi {
  id                  String                      @map("id")                  @db.Uuid            @default(dbgenerated("GEN_RANDOM_UUID()"))

  userId              String                      @map("user_id")             @db.Uuid
  departmentId        String?                     @map("department_id")       @db.Uuid            // For department-level aggregation

  // Period
  year                Int                         @map("year")                @db.Integer
  month               Int                         @map("month")               @db.Integer

  // Scores
  totalBaseScore      Int                         @map("total_base_score")    @db.Integer         @default(0)  // Sum of all base scores
  totalEarnedScore    Int                         @map("total_earned_score")  @db.Integer         @default(0)  // Sum of all earned scores
  totalPenalty        Int                         @map("total_penalty")       @db.Integer         @default(0)  // Sum of all penalties

  // Task counts
  tasksCompleted      Int                         @map("tasks_completed")     @db.Integer         @default(0)
  tasksOnTime         Int                         @map("tasks_on_time")       @db.Integer         @default(0)
  tasksLate           Int                         @map("tasks_late")          @db.Integer         @default(0)

  // Final score (capped at 100 or calculated)
  finalScore          Int                         @map("final_score")         @db.Integer         @default(0)

  // Achievement tracking
  isFullScore         Boolean                     @map("is_full_score")       @db.Boolean         @default(false)  // Did user get 100?
  consecutiveFullMonths Int                       @map("consecutive_full_months") @db.Integer     @default(0)      // Streak of 100s

  // Status
  isFinalized         Boolean                     @map("is_finalized")        @db.Boolean         @default(false)  // Month closed
  finalizedAt         DateTime?                   @map("finalized_at")        @db.Timestamp

  // Breakdown by priority
  // {"priority1": {"count": 2, "earned": 90}, "priority2": {"count": 3, "earned": 45}, ...}
  scoreBreakdown      Json?                       @map("score_breakdown")     @db.JsonB

  reward              KpiReward?

  createdAt           DateTime                    @map("created_at")          @db.Timestamp       @default(now())
  updatedAt           DateTime                    @map("updated_at")          @db.Timestamp       @updatedAt

  @@id([ id ])
  @@unique([userId, year, month])
  @@index([userId])
  @@index([departmentId])
  @@index([year, month])
  @@index([finalScore])
  @@index([isFullScore])
  @@map("user_monthly_kpi")
}

// Department Monthly KPI Summary - Aggregated monthly score per department
model DepartmentMonthlyKpi {
  id                  String                      @map("id")                  @db.Uuid            @default(dbgenerated("GEN_RANDOM_UUID()"))

  departmentId        String                      @map("department_id")       @db.Uuid

  // Period
  year                Int                         @map("year")                @db.Integer
  month               Int                         @map("month")               @db.Integer

  // Aggregated scores
  averageScore        Decimal                     @map("average_score")       @db.Decimal(5, 2)   // Average of all users
  totalScore          Int                         @map("total_score")         @db.Integer         @default(0)

  // User counts
  totalUsers          Int                         @map("total_users")         @db.Integer         @default(0)
  usersAbove85        Int                         @map("users_above_85")      @db.Integer         @default(0)
  usersAt100          Int                         @map("users_at_100")        @db.Integer         @default(0)

  // Team reward eligibility (average 85+)
  isEligibleForTeamReward Boolean                 @map("is_eligible_for_team_reward") @db.Boolean @default(false)

  isFinalized         Boolean                     @map("is_finalized")        @db.Boolean         @default(false)
  finalizedAt         DateTime?                   @map("finalized_at")        @db.Timestamp

  createdAt           DateTime                    @map("created_at")          @db.Timestamp       @default(now())
  updatedAt           DateTime                    @map("updated_at")          @db.Timestamp       @updatedAt

  @@id([ id ])
  @@unique([departmentId, year, month])
  @@index([departmentId])
  @@index([year, month])
  @@index([averageScore])
  @@map("department_monthly_kpi")
}

// KPI Reward - Actual rewards/penalties issued to users
model KpiReward {
  id                  String                      @map("id")                  @db.Uuid            @default(dbgenerated("GEN_RANDOM_UUID()"))

  userMonthlyKpiId    String                      @map("user_monthly_kpi_id") @db.Uuid            @unique
  rewardTierId        String?                     @map("reward_tier_id")      @db.Uuid

  userId              String                      @map("user_id")             @db.Uuid

  // Period
  year                Int                         @map("year")                @db.Integer
  month               Int                         @map("month")               @db.Integer

  // Score that determined reward
  finalScore          Int                         @map("final_score")         @db.Integer

  // Reward/Penalty details
  rewardAmount        Decimal?                    @map("reward_amount")       @db.Decimal(15, 2)
  rewardBhm           Decimal?                    @map("reward_bhm")          @db.Decimal(5, 2)
  isPenalty           Boolean                     @map("is_penalty")          @db.Boolean         @default(false)
  penaltyType         String?                     @map("penalty_type")        @db.VarChar(50)

  // Processing status
  status              KpiRewardStatus             @map("status")              @default(PENDING)

  // Approval workflow
  approvedById        String?                     @map("approved_by_id")      @db.Uuid
  approvedAt          DateTime?                   @map("approved_at")         @db.Timestamp
  paidAt              DateTime?                   @map("paid_at")             @db.Timestamp

  // Notes
  notes               String?                     @map("notes")               @db.Text

  userMonthlyKpi      UserMonthlyKpi              @relation(fields: [userMonthlyKpiId], references: [id], onDelete: Cascade)
  rewardTier          KpiRewardTier?              @relation(fields: [rewardTierId], references: [id])

  createdAt           DateTime                    @map("created_at")          @db.Timestamp       @default(now())
  updatedAt           DateTime                    @map("updated_at")          @db.Timestamp       @updatedAt
  deletedAt           DateTime?                   @map("deleted_at")          @db.Timestamp

  @@id([ id ])
  @@index([userId])
  @@index([year, month])
  @@index([status])
  @@map("kpi_reward")
}

// KPI Special Achievement - Track special achievements (e.g., "Employee of the Year" nomination)
model KpiAchievement {
  id                  String                      @map("id")                  @db.Uuid            @default(dbgenerated("GEN_RANDOM_UUID()"))

  userId              String                      @map("user_id")             @db.Uuid

  // Achievement type
  achievementType     String                      @map("achievement_type")    @db.VarChar(100)    // "EMPLOYEE_OF_YEAR_NOMINATION", "TEAM_AWARD", etc.
  title               String                      @map("title")               @db.VarChar(255)
  description         String?                     @map("description")         @db.Text

  // Period (if applicable)
  year                Int?                        @map("year")                @db.Integer
  month               Int?                        @map("month")               @db.Integer

  // Achievement data
  // {"consecutiveMonths": 3, "scores": [100, 100, 100]}
  metadata            Json?                       @map("metadata")            @db.JsonB

  // Award details (if any)
  awardAmount         Decimal?                    @map("award_amount")        @db.Decimal(15, 2)
  awardedAt           DateTime?                   @map("awarded_at")          @db.Timestamp

  createdAt           DateTime                    @map("created_at")          @db.Timestamp       @default(now())
  updatedAt           DateTime                    @map("updated_at")          @db.Timestamp       @updatedAt

  @@id([ id ])
  @@index([userId])
  @@index([achievementType])
  @@index([year])
  @@map("kpi_achievement")
}

// ============ END KPI SYSTEM ============

// ============ AI CHATBOT ============

model AiMessage {
  id           String    @map("id")           @db.Uuid       @default(dbgenerated("GEN_RANDOM_UUID()"))
  userId       String    @map("user_id")      @db.Uuid
  role         String    @map("role")         @db.VarChar(20)  // user | assistant | tool
  content      String    @map("content")      @db.Text
  toolCalls    Json?     @map("tool_calls")   @db.JsonB
  toolResults  Json?     @map("tool_results") @db.JsonB
  attachments  Json?     @map("attachments")  @db.JsonB
  createdAt    DateTime  @map("created_at")   @db.Timestamp  @default(now())

  @@id([id])
  @@index([userId, createdAt])
  @@map("ai_message")
}
